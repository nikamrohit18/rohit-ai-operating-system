# Copy this file to .env and fill in your values

# Claude API (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL — running on your VPS
DATABASE_URL=postgresql://rohit:password@localhost:5432/rohit_ai_os

# Redis — running on your VPS
REDIS_URL=redis://localhost:6379/0

# Qdrant — running on your VPS (via docker-compose)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Tavily Search API (free tier: 1000 searches/month) — needed in Phase 2
TAVILY_API_KEY=your_tavily_api_key_here

# N8N webhook security — set a random string, add same in N8N HTTP header
N8N_WEBHOOK_SECRET=

# ElevenLabs voice (Phase 4) — get key at elevenlabs.io, copy voice ID from your voice library
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# App environment
APP_ENV=development
